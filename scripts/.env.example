# Copy to scripts/.env and fill in your values. scripts/.env is gitignored.
#
# GITLAB_HOST: Hostname of the target GitLab. For a VPN-only GitLab, pair with
# scripts/install-passthrough.sh so the container can reach it through the Mac.
GITLAB_HOST=gitlab.example.com

# GLAB_CLIENT_ID: OAuth application ID registered in your GitLab (Admin Area or
# User Settings -> Applications). Scopes: api, read_user, read_repository.
# Redirect URI must include http://localhost:7171/auth/redirect.
GLAB_CLIENT_ID=

# MAC_HOST_IP: Only needed with the VPN passthrough. Defaults to 192.168.5.2
# (Rancher Desktop / Lima VM). Docker Desktop users typically don't need this.
# MAC_HOST_IP=192.168.5.2
